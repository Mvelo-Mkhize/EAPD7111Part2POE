@model IEnumerable<EAPD7111Part2POE.Models.Entities.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h1>Clients</h1>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-person-plus"></i> Add New Client
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Company Name</th>
                            <th>Contact Person</th>
                            <th>Email</th>
                            <th>Region</th>
                            <th>Contracts</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in Model)
                        {
                            <tr>
                                <td>@client.CompanyName</td>
                                <td>@client.ContactPerson</td>
                                <td>@client.Email</td>
                                <td>@client.Region</td>
                                <td>
                                    <span class="badge bg-info">@client.Contracts.Count</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@client.ClientId" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@client.ClientId" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@client.ClientId" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>