@model EAPD7111Part2POE.Models.Entities.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h1>Contract Details</h1>
        </div>
        <div class="col text-end">
            <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["FileInfo"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle-fill"></i> @TempData["FileInfo"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Contract Information</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Contract Reference</dt>
                <dd class="col-sm-9">@Model.ContractReference</dd>

                <dt class="col-sm-3">Client</dt>
                <dd class="col-sm-9">@Model.Client?.CompanyName</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Service Level</dt>
                <dd class="col-sm-9">@Model.ServiceLevel</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @{
                        var statusClass = Model.Status.ToString() switch
                        {
                            "Active" => "success",
                            "Draft" => "secondary",
                            "Expired" => "danger",
                            "OnHold" => "warning",
                            _ => "info"
                        };
                    }
                    <span class="badge bg-@statusClass">@Model.Status</span>
                </dd>

                <dt class="col-sm-3">Contract Value</dt>
                <dd class="col-sm-9">@Model.ContractValue.ToString("N2") @Model.Currency</dd>

                <dt class="col-sm-3">Special Terms</dt>
                <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.SpecialTerms) ? "None" : Model.SpecialTerms)</dd>

                <dt class="col-sm-3">Signed Agreement</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <a asp-action="DownloadPDF" asp-route-id="@Model.ContractId" class="btn btn-primary btn-sm" id="downloadPdfBtn">
                                <i class="bi bi-download"></i> Download PDF
                            </a>
                            <span class="text-muted small">
                                <i class="bi bi-file-pdf-fill text-danger"></i>
                                Signed contract document
                            </span>
                            <span class="badge bg-success ms-2">
                                <i class="bi bi-check-circle"></i> Uploaded
                            </span>
                        </div>
                        <div class="mt-2 text-muted small">
                            <i class="bi bi-shield-check"></i> File stored securely with unique identifier
                        </div>
                    }
                    else
                    {
                        <div>
                            <span class="text-muted">
                                <i class="bi bi-info-circle"></i> No signed agreement uploaded
                            </span>
                            <span class="badge bg-secondary ms-2">Optional</span>
                        </div>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Service Requests</h5>
        </div>
        <div class="card-body">
            @if (Model.ServiceRequests.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Request Type</th>
                                <th>Description</th>
                                <th>Cost</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.ServiceRequests)
                            {
                                <tr>
                                    <td>@request.RequestType</td>
                                    <td>@request.Description</td>
                                    <td>@request.Cost.ToString("N2") @request.Currency</td>
                                    <td>@request.Priority</td>
                                    <td>
                                        <span class="badge @(request.Status.ToString() == "Pending" ? "bg-warning" : "bg-success")">
                                            @request.Status
                                        </span>
                                    </td>
                                    <td>@request.RequestDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a asp-controller="ServiceRequests" asp-action="Details" asp-route-id="@request.ServiceRequestId" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No service requests for this contract.</p>
            }

            @if (Model.IsActive)
            {
                <a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@Model.ContractId" class="btn btn-primary mt-2">
                    <i class="bi bi-plus"></i> Create Service Request
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#downloadPdfBtn').on('click', function (e) {
                console.log('PDF download initiated for contract: @Model.ContractReference');

                var notification = $('<div class="alert alert-info alert-dismissible fade show position-fixed top-0 end-0 m-3" style="z-index: 9999;" role="alert">' +
                    '<i class="bi bi-download"></i> Download started...' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '</div>');
                $('body').append(notification);

                setTimeout(function () {
                    notification.alert('close');
                }, 3000);
            });
        });
    </script>
}