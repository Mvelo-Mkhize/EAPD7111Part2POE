@model IEnumerable<EAPD7111Part2POE.Models.Entities.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h1>Contracts</h1>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-file-earmark-plus"></i> Create Contract
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Contract Ref</th>
                            <th>Client</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Service Level</th>
                            <th>Status</th>
                            <th>Value</th>
                            <th>Signed Agreement</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contract in Model)
                        {
                            <tr>
                                <td>@contract.ContractReference</td>
                                <td>@contract.Client?.CompanyName</td>
                                <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>@contract.ServiceLevel</td>
                                <td>
                                    @{
                                        var statusClass = contract.Status.ToString() switch
                                        {
                                            "Active" => "success",
                                            "Draft" => "secondary",
                                            "Expired" => "danger",
                                            "OnHold" => "warning",
                                            _ => "info"
                                        };
                                    }
                                    <span class="badge bg-@statusClass">@contract.Status</span>
                                </td>
                                <td>@contract.ContractValue @contract.Currency</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                                    {
                                        <span class="badge bg-success">Uploaded</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Not Uploaded</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@contract.ContractId" class="btn btn-sm btn-info">View</a>
                                    <a asp-action="Edit" asp-route-id="@contract.ContractId" class="btn btn-sm btn-warning">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@contract.ContractId" class="btn btn-sm btn-danger">Delete</a>
                                    @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                                    {
                                        <a asp-action="DownloadPDF" asp-route-id="@contract.ContractId" class="btn btn-sm btn-secondary">PDF</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>