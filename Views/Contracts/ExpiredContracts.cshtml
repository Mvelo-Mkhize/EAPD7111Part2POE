@model IEnumerable<EAPD7111Part2POE.Models.Entities.Contract>

@{
    ViewData["Title"] = "Compliance Report - Expired Contracts";
}

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h1>Compliance Report</h1>
            <p class="text-danger">⚠️ Expired and Non-Compliant Contracts</p>
        </div>
        <div class="col text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Contracts
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <strong>Compliance Issue Detected:</strong> The following contracts are expired, which may lead to service disruptions, legal issues, and financial penalties. Immediate action is required.
    </div>

    <!-- Expired Contracts Section -->
    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">
                <i class="bi bi-calendar-x"></i> Expired Contracts
                <span class="badge bg-light text-dark ms-2">@Model.Count()</span>
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Contract Reference</th>
                                <th>Client</th>
                                <th>Region</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Days Expired</th>
                                <th>Service Level</th>
                                <th>Value</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in Model)
                            {
                                var daysExpired = (DateTime.UtcNow - contract.EndDate).Days;
                                <tr class="table-danger">
                                    <td>
                                        <strong>@contract.ContractReference</strong>
                                        @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                                        {
                                            <a asp-action="DownloadPDF" asp-route-id="@contract.ContractId" class="ms-2 text-info" title="Download PDF">
                                                <i class="bi bi-file-pdf"></i>
                                            </a>
                                        }
                                    </td>
                                    <td>@contract.Client?.CompanyName</td>
                                    <td>@contract.Client?.Region</td>
                                    <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <span class="badge bg-danger">@daysExpired days</span>
                                    </td>
                                    <td>@contract.ServiceLevel</td>
                                    <td>@contract.ContractValue.ToString("N2") @contract.Currency</td>
                                    <td>
                                        <span class="badge bg-danger">Expired</span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@contract.ContractId" class="btn btn-sm btn-info" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@contract.ContractId" class="btn btn-sm btn-warning" title="Renew Contract">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-primary" onclick="sendReminder(@contract.ContractId, '@contract.Client?.Email')" title="Send Reminder">
                                                <i class="bi bi-envelope"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <div class="alert alert-info">
                        <strong>Summary:</strong>
                        Total Expired Contracts: @Model.Count() |
                        Total Value at Risk: @Model.Sum(c => c.ContractValue).ToString("N2") @Model.FirstOrDefault()?.Currency
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 48px;"></i>
                    <h4 class="text-success mt-3">No Expired Contracts</h4>
                    <p class="text-muted">All contracts are currently in compliance.</p>
                </div>
            }
        </div>
    </div>

    <!-- Contracts Expiring Soon Section -->
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">
                <i class="bi bi-clock-history"></i> Contracts Expiring Soon (Next 30 Days)
                <span class="badge bg-dark text-white ms-2">@(((List<EAPD7111Part2POE.Models.Entities.Contract>)ViewBag.ExpiringContracts).Count)</span>
            </h5>
        </div>
        <div class="card-body">
            @if (((List<EAPD7111Part2POE.Models.Entities.Contract>)ViewBag.ExpiringContracts).Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Contract Reference</th>
                                <th>Client</th>
                                <th>Region</th>
                                <th>End Date</th>
                                <th>Days Left</th>
                                <th>Service Level</th>
                                <th>Value</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in ViewBag.ExpiringContracts)
                            {
                                <tr class="table-warning">
                                    <td>
                                        <strong>@contract.ContractReference</strong>
                                        @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                                        {
                                            <a asp-action="DownloadPDF" asp-route-id="@contract.ContractId" class="ms-2 text-info" title="Download PDF">
                                                <i class="bi bi-file-pdf"></i>
                                            </a>
                                        }
                                    </td>
                                    <td>@contract.Client.CompanyName</td>
                                    <td>@contract.Client.Region</td>
                                    <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (contract.DaysUntilExpiry <= 7)
                                        {
                                            <span class="badge bg-danger">@contract.DaysUntilExpiry days (Critical)</span>
                                        }
                                        else if (contract.DaysUntilExpiry <= 14)
                                        {
                                            <span class="badge bg-warning text-dark">@contract.DaysUntilExpiry days (Urgent)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">@contract.DaysUntilExpiry days</span>
                                        }
                                    </td>
                                    <td>@contract.ServiceLevel</td>
                                    <td>@contract.ContractValue.ToString("N2") @contract.Currency</td>
                                    <td>
                                        <span class="badge bg-warning text-dark">Active (Expiring Soon)</span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@contract.ContractId" class="btn btn-sm btn-info" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@contract.ContractId" class="btn btn-sm btn-success" title="Extend Contract">
                                                <i class="bi bi-calendar-plus"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-primary" onclick="sendReminder(@contract.ContractId, '@contract.Client.Email')" title="Send Reminder">
                                                <i class="bi bi-envelope"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <div class="alert alert-warning">
                        <strong>Action Required:</strong>
                        @(((List<EAPD7111Part2POE.Models.Entities.Contract>)ViewBag.ExpiringContracts).Count) contracts require attention within the next 30 days.
                        @if (((List<EAPD7111Part2POE.Models.Entities.Contract>)ViewBag.ExpiringContracts).Count(c => c.DaysUntilExpiry <= 7) > 0)
                        {
                            <text>⚠️ @(((List<EAPD7111Part2POE.Models.Entities.Contract>)ViewBag.ExpiringContracts).Count(c => c.DaysUntilExpiry <= 7)) contracts are critical (within 7 days)!</text>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-calendar-check text-success" style="font-size: 48px;"></i>
                    <h4 class="text-success mt-3">No Contracts Expiring Soon</h4>
                    <p class="text-muted">All active contracts have more than 30 days remaining.</p>
                </div>
            }
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-tools"></i> Compliance Actions</h5>
                </div>
                <div class="card-body">
                    <div class="btn-group" role="group">
                        <button class="btn btn-primary" onclick="generateComplianceReport()">
                            <i class="bi bi-download"></i> Download Compliance Report
                        </button>
                        <button class="btn btn-danger" onclick="sendBulkReminder()">
                            <i class="bi bi-envelope-paper"></i> Send Bulk Reminder
                        </button>
                        <button class="btn btn-success" onclick="location.reload()">
                            <i class="bi bi-arrow-clockwise"></i> Refresh
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function sendReminder(contractId, email) {
            if (confirm(`Send compliance reminder to ${email}?`)) {
                $.ajax({
                    url: '@Url.Action("SendComplianceReminder", "Contracts")',
                    type: 'POST',
                    data: { contractId: contractId },
                    success: function (response) {
                        alert('Reminder sent successfully!');
                    },
                    error: function () {
                        alert('Failed to send reminder. Please try again.');
                    }
                });
            }
        }

        function sendBulkReminder() {
            if (confirm('Send bulk compliance reminders to all clients with expired/expiring contracts?')) {
                $.ajax({
                    url: '@Url.Action("SendBulkComplianceReminder", "Contracts")',
                    type: 'POST',
                    success: function (response) {
                        alert('Bulk reminders sent successfully!');
                    },
                    error: function () {
                        alert('Failed to send bulk reminders. Please try again.');
                    }
                });
            }
        }

        function generateComplianceReport() {
            window.location.href = '@Url.Action("ExportComplianceReport", "Contracts")';
        }

        // Highlight rows based on urgency
        $(document).ready(function () {
            $('table tbody tr').each(function () {
                var daysCell = $(this).find('td:eq(4)');
                if (daysCell.length) {
                    var daysText = daysCell.text();
                    if (daysText.includes('Critical')) {
                        $(this).css('background-color', '#ffebee');
                    } else if (daysText.includes('Urgent')) {
                        $(this).css('background-color', '#fff3e0');
                    }
                }
            });
        });
    </script>
}