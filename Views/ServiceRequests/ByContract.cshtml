@model IEnumerable<EAPD7111Part2POE.Models.Entities.ServiceRequest>

@{
    var contract = ViewBag.Contract as EAPD7111Part2POE.Models.Entities.Contract;
    ViewData["Title"] = $"Service Requests - {contract?.ContractReference}";
}

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h1>Service Requests for @contract?.ContractReference</h1>
            <p class="text-muted">Client: @contract?.Client?.CompanyName</p>
        </div>
        <div class="col text-end">
            <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract?.ContractId" class="btn btn-secondary">
                Back to Contract
            </a>
            @if (contract?.IsActive == true)
            {
                <a asp-action="Create" asp-route-contractId="@contract?.ContractId" class="btn btn-primary">
                    New Service Request
                </a>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">All Service Requests</h5>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Request Type</th>
                                <th>Description</th>
                                <th>Cost</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Request Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr>
                                    <td>@request.RequestType</td>
                                    <td>@request.Description</td>
                                    <td>@request.Cost @request.Currency</td>
                                    <td>@request.Priority</td>
                                    <td>
                                        <span class="badge @(request.Status.ToString() == "Pending" ? "bg-warning" : "bg-success")">
                                            @request.Status
                                        </span>
                                    </td>
                                    <td>@request.RequestDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@request.ServiceRequestId" class="btn btn-sm btn-info">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <h5>Summary</h5>
                    <p><strong>Total Requests:</strong> @Model.Count()</p>
                    <p><strong>Total Cost:</strong> @Model.Sum(r => r.Cost) @contract?.Currency</p>
                </div>
            }
            else
            {
                <p class="text-muted">No service requests found for this contract.</p>
            }
        </div>
    </div>
</div>