@model EAPD7111Part2POE.Models.Entities.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Raise New Service Request</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <strong><i class="bi bi-info-circle"></i> Note:</strong> Service requests can only be created against <strong>ACTIVE</strong> contracts.
                        The system will automatically validate the contract status.
                    </div>

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="ContractId" class="form-label"></label>
                            <select asp-for="ContractId" class="form-control" id="ContractSelect">
                                <option value="">-- Select Active Contract --</option>
                                @foreach (var contract in ViewBag.ActiveContracts)
                                {
                                    if (ViewBag.SelectedContractId == contract.ContractId)
                                    {
                                        <option value="@contract.ContractId" selected>
                                            @contract.ContractReference - @contract.Client.CompanyName (Valid until: @contract.EndDate.ToString("yyyy-MM-dd"))
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@contract.ContractId">
                                            @contract.ContractReference - @contract.Client.CompanyName (Valid until: @contract.EndDate.ToString("yyyy-MM-dd"))
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ContractId" class="text-danger"></span>
                            <div id="ContractValidationMessage" class="mt-2"></div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RequestType" class="form-label"></label>
                            <select asp-for="RequestType" class="form-control">
                                <option value="Freight">Freight</option>
                                <option value="Warehousing">Warehousing</option>
                                <option value="Customs Clearance">Customs Clearance</option>
                                <option value="Documentation">Documentation</option>
                                <option value="Insurance">Insurance</option>
                            </select>
                            <span asp-validation-for="RequestType" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" rows="3" class="form-control" placeholder="Describe the service required..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Cost" class="form-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text" id="currencySymbol">$</span>
                                        <input asp-for="Cost" type="number" step="0.01" class="form-control" id="CostAmount" />
                                    </div>
                                    <span asp-validation-for="Cost" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Currency" class="form-label"></label>
                                    <select asp-for="Currency" class="form-control" id="CurrencySelect">
                                        <option value="USD">USD - US Dollar</option>
                                        <option value="EUR">EUR - Euro</option>
                                        <option value="GBP">GBP - British Pound</option>
                                        <option value="JPY">JPY - Japanese Yen</option>
                                        <option value="CAD">CAD - Canadian Dollar</option>
                                        <option value="AUD">AUD - Australian Dollar</option>
                                        <option value="ZAR">ZAR - South African Rand</option>
                                    </select>
                                    <span asp-validation-for="Currency" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row" id="ZarConversionPanel" style="display: none;">
                            <div class="col-md-12">
                                <div class="alert alert-success">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="bi bi-currency-exchange fs-4"></i>
                                            <strong>Local Cost (ZAR):</strong>
                                            <span id="ZarAmount" class="fs-4 fw-bold">0.00</span> ZAR
                                        </div>
                                        <div class="text-end">
                                            <small class="text-muted">
                                                Exchange Rate: 1 USD = <span id="ExchangeRate">0.00</span> ZAR
                                                <br />
                                                <span id="RateTimestamp" class="small"></span>
                                            </small>
                                        </div>
                                    </div>
                                    <div class="progress mt-2" style="height: 5px;">
                                        <div id="ConversionProgress" class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" asp-for="CostInZAR" id="CostInZAR" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Priority" class="form-label"></label>
                                    <select asp-for="Priority" class="form-control">
                                        <option value="Low">Low</option>
                                        <option value="Medium" selected="selected">Medium</option>
                                        <option value="High">High</option>
                                        <option value="Critical">Critical</option>
                                    </select>
                                    <span asp-validation-for="Priority" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Request Date</label>
                                    <input type="text" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd HH:mm")" disabled />
                                    <small class="text-muted">Auto-generated on submission</small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SpecialInstructions" class="form-label"></label>
                            <textarea asp-for="SpecialInstructions" rows="2" class="form-control" placeholder="Any special instructions for this service request..."></textarea>
                            <span asp-validation-for="SpecialInstructions" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Submit Service Request
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let currentExchangeRate = 0;
        let lastFetchTime = null;

        $(document).ready(function () {
            function updateCurrencySymbol() {
                var currency = $('#CurrencySelect').val();
                var symbol = '$';
                switch (currency) {
                    case 'USD': symbol = '$'; break;
                    case 'EUR': symbol = '€'; break;
                    case 'GBP': symbol = '£'; break;
                    case 'JPY': symbol = '¥'; break;
                    case 'CAD': symbol = 'C$'; break;
                    case 'AUD': symbol = 'A$'; break;
                    case 'ZAR': symbol = 'R'; break;
                }
                $('#currencySymbol').text(symbol);
            }

            fetchUSDtoZARRate();

            $('#CostAmount').on('input', function () {
                calculateZARAmount();
                updateProgressBar();
            });

            $('#CurrencySelect').on('change', function () {
                updateCurrencySymbol();
                if ($(this).val() === 'USD') {
                    $('#ZarConversionPanel').slideDown();
                    calculateZARAmount();
                } else {
                    $('#ZarConversionPanel').slideUp();
                    $('#CostInZAR').val('');
                }
            });

            $('#CostAmount').on('focus', function () {
                $(this).parent().parent().addClass('border-primary');
            }).on('blur', function () {
                $(this).parent().parent().removeClass('border-primary');
                if ($(this).val() && $('#CurrencySelect').val() === 'USD') {
                    calculateZARAmount();
                }
            });

            function updateProgressBar() {
                var usdAmount = parseFloat($('#CostAmount').val());
                if (!isNaN(usdAmount) && usdAmount > 0 && currentExchangeRate > 0) {
                    var zarAmount = usdAmount * currentExchangeRate;
                    var maxZar = 1000000;         
                    var percentage = Math.min((zarAmount / maxZar) * 100, 100);
                    $('#ConversionProgress').css('width', percentage + '%');
                } else {
                    $('#ConversionProgress').css('width', '0%');
                }
            }

            updateCurrencySymbol();
            if ($('#CurrencySelect').val() === 'USD') {
                $('#ZarConversionPanel').show();
            }

            $('#ContractSelect').change(function () {
                var contractId = $(this).val();
                if (contractId) {
                    $.ajax({
                        url: '@Url.Action("ValidateContract", "Contracts")',
                        type: 'GET',
                        data: { id: contractId },
                        success: function (data) {
                            if (data.isValid) {
                                $('#ContractValidationMessage').html(
                                    '<div class="alert alert-success">' +
                                    '<i class="bi bi-check-circle-fill"></i> ✓ Contract is valid and active. ' +
                                    'Expires in ' + data.daysUntilExpiry + ' days.</div>'
                                );
                            } else {
                                $('#ContractValidationMessage').html(
                                    '<div class="alert alert-danger">' +
                                    '<i class="bi bi-exclamation-triangle-fill"></i> ✗ Contract is ' + data.contractStatus +
                                    '. Cannot create service request against this contract.</div>'
                                );
                            }
                        }
                    });
                } else {
                    $('#ContractValidationMessage').empty();
                }
            });

            if ($('#ContractSelect').val()) {
                $('#ContractSelect').trigger('change');
            }
        });

        function fetchUSDtoZARRate() {
            $('#ExchangeRate').html('<div class="spinner-border spinner-border-sm" role="status"></div>');

            $.ajax({
                url: '@Url.Action("GetUSDtoZARRate", "Financial")',
                type: 'GET',
                success: function (data) {
                    if (data.success) {
                        currentExchangeRate = data.rate;
                        lastFetchTime = data.timestamp;
                        $('#ExchangeRate').text(currentExchangeRate.toFixed(4));
                        $('#RateTimestamp').html(`<i class="bi bi-clock"></i> Rate fetched: ${new Date(data.timestamp).toLocaleString()}`);
                        calculateZARAmount();

                        $('#ZarConversionPanel .alert').addClass('alert-success').removeClass('alert-warning');
                    } else {
                        console.error('Failed to fetch exchange rate');
                        $('#ExchangeRate').text('Unavailable');
                        $('#RateTimestamp').text('Please refresh the page to try again');
                        $('#ZarConversionPanel .alert').addClass('alert-warning').removeClass('alert-success');
                    }
                },
                error: function () {
                    console.error('Error fetching exchange rate');
                    $('#ExchangeRate').text('Error fetching rate');
                    $('#RateTimestamp').text('Unable to connect to exchange rate service');
                    $('#ZarConversionPanel .alert').addClass('alert-danger').removeClass('alert-success');
                }
            });
        }

        function calculateZARAmount() {
            var usdAmount = parseFloat($('#CostAmount').val());
            var currency = $('#CurrencySelect').val();

            if (currency === 'USD' && !isNaN(usdAmount) && usdAmount > 0 && currentExchangeRate > 0) {
                var zarAmount = usdAmount * currentExchangeRate;
                $('#ZarAmount').text(zarAmount.toFixed(2));
                $('#CostInZAR').val(zarAmount.toFixed(2));

                var zarPanel = $('#ZarAmount');
                zarPanel.css('transform', 'scale(1.1)');
                setTimeout(function () {
                    zarPanel.css('transform', 'scale(1)');
                }, 200);
            } else if (currency === 'USD' && (!isNaN(usdAmount) && usdAmount > 0) && currentExchangeRate === 0) {
                $('#ZarAmount').text('Loading rate...');
                $('#CostInZAR').val('');
            } else if (currency === 'USD') {
                $('#ZarAmount').text('0.00');
                $('#CostInZAR').val('');
            }
        }

        setInterval(function () {
            if ($('#CurrencySelect').val() === 'USD') {
                fetchUSDtoZARRate();
            }
        }, 300000);   
    </script>

    <style>
        .highlight {
            animation: highlightFlash 0.5s ease-in-out;
        }

        @@keyframes highlightFlash {
            0% {
                background-color: transparent;
            }

            50% {
                background-color: rgba(40, 167, 69, 0.2);
            }

            100% {
                background-color: transparent;
            }
        }

        #ZarAmount {
            transition: transform 0.2s ease-in-out;
            display: inline-block;
        }

        .input-group:focus-within {
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
            border-radius: 0.375rem;
        }

        .progress {
            overflow: hidden;
        }

        .progress-bar {
            transition: width 0.3s ease-in-out;
        }
    </style>
}